{
  "extends": "./node_modules/adonis-preset-ts/tsconfig",
  "compilerOptions": {
    "rootDir": "./",
    "typeRoots": ["./types"],
    "target": "es2021",
    "module": "commonjs",
    "incremental": true,
    "removeComments": false,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react"
  },
  "references": [
    {
      "path": "./packages/radonis/tsconfig.json"
    },
    {
      "path": "./packages/radonis-server/tsconfig.json"
    },
  ]
}
