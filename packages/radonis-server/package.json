{
  "name": "@microeinhundert/radonis-server",
  "version": "0.1.1",
  "description": "Bridge the gap between React and AdonisJS",
  "main": "build/providers/RadonisProvider/index.js",
  "types": "build/adonis-typings/index.d.ts",
  "typings": "build/adonis-typings/index.d.ts",
  "files": [
    "build/providers",
    "build/adonis-typings",
    "build/instructions.md"
  ],
  "scripts": {
    "clean": "del build",
    "copyfiles": "copyfiles \"instructions.md\" build",
    "compile": "npm run lint && npm run clean && tsc",
    "build": "npm run compile && npm run copyfiles",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/microeinhundert/radonis-server.git"
  },
  "bugs": {
    "url": "https://github.com/microeinhundert/radonis-server/issues"
  },
  "keywords": [
    "adonisjs",
    "radonis-server"
  ],
  "author": "Leon Seipp <l.seipp@microeinhundert.com>",
  "license": "MIT",
  "peerDependencies": {
    "@microeinhundert/radonis": "^0.1.1",
    "@adonisjs/core": "^5.0.0",
    "@adonisjs/session": "^6.0.0",
    "@adonisjs/shield": "^7.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "adonisjs": {
    "instructionsMd": "./build/instructions.md",
    "types": "@microeinhundert/radonis-server",
    "providers": [
      "@microeinhundert/radonis-server"
    ]
  },
  "devDependencies": {
    "@adonisjs/core": "^5.0.0",
    "@adonisjs/session": "^6.0.0",
    "@adonisjs/shield": "^7.0.0",
    "@types/node": "^16",
    "@types/react": "^17.0.43",
    "@types/react-dom": "^17.0.14"
  },
  "dependencies": {
    "node-object-hash": "^2.3.10"
  }
}
