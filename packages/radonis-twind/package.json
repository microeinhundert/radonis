{
  "name": "@microeinhundert/radonis-twind",
  "version": "0.4.2",
  "description": "Twind library for Radonis",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "typings": "build/src/index.d.ts",
  "sideEffects": false,
  "files": [
    "build/src"
  ],
  "scripts": {
    "clean": "del build",
    "compile": "npm run lint && npm run clean && tsc",
    "build": "npm run compile",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/microeinhundert/radonis.git"
  },
  "bugs": {
    "url": "https://github.com/microeinhundert/radonis/issues"
  },
  "engines": {
    "node": ">= 16.0.0",
    "npm": ">= 8.0.0",
    "yarn": ">= 2.0.0"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "radonis",
    "twind"
  ],
  "author": "Leon Seipp <l.seipp@microeinhundert.com>",
  "license": "MIT",
  "peerDependencies": {
    "@microeinhundert/radonis": "*",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^16",
    "@types/react": "^18.0.3",
    "@types/react-dom": "^18.0.0"
  },
  "dependencies": {
    "@twind/preset-autoprefix": "1.0.0-next.37",
    "@twind/preset-tailwind": "1.0.0-next.37",
    "@twind/preset-tailwind-forms": "1.0.0-next.37",
    "twind": "1.0.0-next.37"
  }
}
