{
  "name": "@microeinhundert/radonis",
  "version": "0.5.0",
  "description": "Bridge the gap between React and AdonisJS",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "typings": "build/src/index.d.ts",
  "sideEffects": false,
  "files": [
    "build/src"
  ],
  "scripts": {
    "clean": "del build",
    "compile": "pnpm run clean && tsc",
    "build": "pnpm run compile",
    "prepublishOnly": "pnpm run build",
    "lint": "TIMING=1 eslint .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/microeinhundert/radonis.git"
  },
  "bugs": {
    "url": "https://github.com/microeinhundert/radonis/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">= 16.0.0",
    "npm": ">= 8.0.0",
    "yarn": ">= 2.0.0"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "radonis"
  ],
  "author": "Leon Seipp <l.seipp@microeinhundert.com>",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^16"
  },
  "dependencies": {
    "@microeinhundert/radonis-hooks": "workspace:*",
    "@microeinhundert/radonis-server": "workspace:*",
    "@microeinhundert/radonis-twind": "workspace:*",
    "@microeinhundert/radonis-hydrate": "workspace:*"
  }
}
