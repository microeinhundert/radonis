{
  "name": "@microeinhundert/radonis-shared",
  "version": "0.4.2",
  "description": "Shared library for Radonis",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "typings": "build/src/index.d.ts",
  "sideEffects": false,
  "files": [
    "build/src"
  ],
  "scripts": {
    "clean": "del build",
    "compile": "npm run lint && npm run clean && tsc",
    "build": "npm run compile",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/microeinhundert/radonis.git"
  },
  "bugs": {
    "url": "https://github.com/microeinhundert/radonis/issues"
  },
  "engines": {
    "node": ">= 16.0.0",
    "npm": ">= 8.0.0",
    "yarn": ">= 2.0.0"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "radonis",
    "shared"
  ],
  "author": "Leon Seipp <l.seipp@microeinhundert.com>",
  "license": "MIT",
  "peerDependencies": {
    "@microeinhundert/radonis": "*"
  },
  "devDependencies": {
    "@types/node": "^16"
  }
}
